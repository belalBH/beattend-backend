  file_change {
    absolute_path_uri: "file:///laravel/README.md"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "# \360\237\224\245 \330\257\331\204\331\212\331\204 \330\252\330\255\331\210\331\212\331\204 \330\254\330\263\330\261 \330\250\330\261\331\210 \331\203\330\247\331\205\331\204 \330\245\331\204\331\211 PHP Laravel\n\n\330\243\331\207\331\204\330\247\331\213 \330\250\331\203! \330\252\331\205 \330\252\330\255\331\210\331\212\331\204 \330\247\331\204\331\206\330\270\330\247\331\205 \330\250\330\247\331\204\331\203\330\247\331\205\331\204 \331\210\330\254\330\247\331\207\330\262 \331\204\331\204\330\252\330\265\330\257\331\212\330\261 \331\210\330\247\331\204\330\252\330\253\330\250\331\212\330\252 \330\271\331\204\331\211 \330\256\330\247\330\257\331\205\331\203 \330\247\331\204\331\205\330\255\331\204\331\212 \330\243\331\210 \330\247\331\204\330\263\330\255\330\247\330\250\331\212 \330\250\330\247\330\263\330\252\330\256\330\257\330\247\331\205 **PHP Laravel** \331\205\330\271 \331\210\330\247\330\254\331\207\330\251 **React** \330\247\331\204\330\252\331\201\330\247\330\271\331\204\331\212\330\251 \330\250\330\247\330\263\330\252\330\271\331\205\330\247\331\204 **Laravel Vite**.\n\n---\n\n## \360\237\223\202 \330\247\331\204\331\207\331\212\331\203\331\204 \330\247\331\204\331\205\330\247\331\204\331\212 \331\210\330\247\331\204\331\205\330\254\331\204\331\221\330\257\330\247\330\252 \330\247\331\204\330\254\330\257\331\212\330\257\330\251 \331\204\331\200 Laravel\n\330\252\331\205 \330\245\331\206\330\264\330\247\330\241 \331\210\330\252\331\210\331\204\331\212\330\257 \330\247\331\204\331\205\331\204\331\201\330\247\330\252 \330\247\331\204\331\204\330\247\330\262\331\205\330\251 \331\204\331\206\330\270\330\247\331\205\331\203 \331\201\331\212 \331\205\330\254\331\204\330\257 `/laravel`:\n- **\331\202\331\210\330\247\330\271\330\257 \330\247\331\204\330\250\331\212\330\247\331\206\330\247\330\252 (Migrations):** \330\257\330\247\330\256\331\204 `database/migrations` (\330\247\331\204\330\264\330\261\331\203\330\247\330\252\330\214 \330\247\331\204\330\243\331\202\330\263\330\247\331\205\330\214 \330\247\331\204\331\205\331\210\330\270\331\201\331\212\331\206\330\214 \331\206\330\267\330\247\331\202\330\247\330\252 \330\247\331\204\331\201\330\261\331\210\330\271 \330\247\331\204\330\254\330\272\330\261\330\247\331\201\331\212\330\251).\n- **\330\247\331\204\331\206\331\205\330\247\330\260\330\254 \330\247\331\204\330\260\331\203\331\212\330\251 (Model Relationships):** \331\201\331\212 `app/Models` (\330\247\331\204\330\264\330\261\331\203\330\247\330\252 \331\210\330\247\331\204\331\205\331\210\330\270\331\201\331\212\331\206 \331\205\330\271 \330\247\331\204\330\271\331\204\330\247\331\202\330\247\330\252 `hasMany` \331\210 `belongsTo`).\n- **\330\247\331\204\331\205\330\252\330\255\331\203\331\205\330\247\330\252 (Controllers):** \331\201\331\212 `app/Http/Controllers` \331\204\330\252\331\202\330\257\331\212\331\205 \330\247\330\263\330\252\330\254\330\247\330\250\330\247\330\252 JSON \330\263\330\261\331\212\330\271\330\251 \331\205\330\252\331\210\330\247\331\201\331\202\330\251 \331\205\330\271 \331\210\330\247\330\254\331\207\330\247\330\252 React.\n- **\331\205\330\263\330\247\330\261\330\247\330\252 \330\247\331\204\331\210\331\212\330\250 \331\210\330\247\331\204\331\200 API:** \331\201\331\212 `routes/api.php` \331\210 `routes/web.php` (\330\252\330\252\330\266\331\205\331\206 \331\201\330\255\330\265 \330\247\331\204\330\245\330\255\330\257\330\247\330\253\331\212\330\247\330\252 \330\247\331\204\330\254\330\272\330\261\330\247\331\201\331\212\330\251 \330\271\330\250\330\261 \331\205\330\271\330\247\330\257\331\204\330\251 \331\207\330\247\331\201\331\212\330\261\330\263\331\212\331\206 \330\247\331\204\330\254\331\212\330\250\331\212\330\251 \330\252\331\204\331\202\330\247\330\246\331\212\330\247\331\213).\n- **\330\247\331\204\331\202\331\210\330\247\331\204\330\250 (Blade Views):** \331\201\331\212 `resources/views/app.blade.php`.\n\n---\n\n## \360\237\233\240\357\270\217 \330\256\330\267\331\210\330\247\330\252 \330\247\331\204\330\252\330\264\330\272\331\212\331\204 \331\210\330\247\331\204\330\252\330\253\330\250\331\212\330\252 \330\247\331\204\331\201\331\210\330\261\331\212\n\n### 1\357\270\217\342\203\243 \330\247\331\204\331\205\330\252\330\267\331\204\330\250\330\247\330\252 \330\247\331\204\330\243\330\263\330\247\330\263\331\212\330\251\n\330\252\330\243\331\203\330\257 \331\205\331\206 \330\252\331\206\330\265\331\212\330\250 \330\247\331\204\330\252\330\247\331\204\331\212 \330\271\331\204\331\211 \330\254\331\207\330\247\330\262\331\203:\n- **PHP** (\330\247\331\204\330\245\330\265\330\257\330\247\330\261 8.1 \330\243\331\210 \330\243\330\255\330\257\330\253)\n- **Composer** \331\204\330\245\330\257\330\247\330\261\330\251 \330\255\330\262\331\205 PHP\n- **Node.js & NPM** \331\204\330\245\330\257\330\247\330\261\330\251 \330\255\330\262\331\205 \330\247\331\204\331\210\330\247\330\254\331\207\330\251 \330\247\331\204\330\243\331\205\330\247\331\205\331\212\330\251\n\n### 2\357\270\217\342\203\243 \330\252\330\253\330\250\331\212\330\252 \330\255\330\262\331\205 \331\210\330\247\330\254\331\207\330\247\330\252 \330\247\331\204\330\256\331\204\331\201\331\212\330\251 \331\210\330\247\331\204\330\243\331\205\330\247\331\205\331\212\330\251\n\331\202\331\205 \330\250\331\201\330\252\330\255 \330\247\331\204\331\205\330\254\331\204\330\257 \331\210\330\247\331\203\330\252\330\250 \330\247\331\204\330\243\331\210\330\247\331\205\330\261 \330\247\331\204\330\252\330\247\331\204\331\212\330\251:\n```bash\n# \330\252\330\253\330\250\331\212\330\252 \330\255\330\262\331\205 Laravel \330\247\331\204\330\256\331\204\331\201\331\212\330\251\ncomposer install\n\n# \330\252\330\253\330\250\331\212\330\252 \330\255\330\262\331\205 React \330\247\331\204\330\243\331\205\330\247\331\205\331\212\330\251\nnpm install\n```\n\n### 3\357\270\217\342\203\243 \330\245\330\271\330\257\330\247\330\257 \330\247\331\204\330\250\331\212\330\246\330\251 \331\210\331\202\331\210\330\247\330\271\330\257 \330\247\331\204\330\250\331\212\330\247\331\206\330\247\330\252 `.env`\n\331\202\331\205 \330\250\331\206\330\263\330\256 \331\205\331\204\331\201 \330\247\331\204\330\245\330\271\330\257\330\247\330\257 \330\247\331\204\330\247\331\201\330\252\330\261\330\247\330\266\331\212 \331\210\330\266\330\250\330\267 \330\245\330\271\330\257\330\247\330\257\330\247\330\252 \331\202\330\247\330\271\330\257\330\251 \330\247\331\204\330\250\331\212\330\247\331\206\330\247\330\252 \330\247\331\204\330\256\330\247\330\265\330\251 \330\250\331\203 (MySQL / PostgreSQL):\n```bash\ncp .env.example .env\n```\n\330\247\331\201\330\252\330\255 \331\205\331\204\331\201 `.env` \331\210\331\202\331\205 \330\250\330\252\330\271\330\257\331\212\331\204 \330\250\331\212\330\247\331\206\330\247\330\252 \330\247\331\204\330\247\330\252\330\265\330\247\331\204:\n```env\nDB_CONNECTION=mysql\nDB_HOST=127.0.0.1\nDB_PORT=3306\nDB_DATABASE=jesr_db\nDB_USERNAME=root\nDB_PASSWORD=your_password\n```\n\330\253\331\205 \331\202\331\205 \330\250\330\252\331\210\331\204\331\212\330\257 \331\205\331\201\330\252\330\247\330\255 \330\255\331\205\330\247\331\212\330\251 \330\247\331\204\330\252\330\267\330\250\331\212\331\202:\n```bash\nphp artisan key:generate\n```\n\n### 4\357\270\217\342\203\243 \330\252\330\261\330\255\331\212\331\204 \330\254\330\257\330\247\331\210\331\204 \331\202\331\210\330\247\330\271\330\257 \330\247\331\204\330\250\331\212\330\247\331\206\330\247\330\252 (Migrations)\n\331\202\331\205 \330\250\330\252\330\261\330\255\331\212\331\204 \330\247\331\204\330\254\330\257\330\247\331\210\331\204 \331\204\330\252\330\243\330\263\331\212\330\263 \331\207\331\212\331\203\331\204 \330\247\331\204\330\264\330\261\331\203\330\247\330\252 \331\210\330\247\331\204\331\205\331\210\330\270\331\201\331\212\331\206 \331\210\330\247\331\204\330\252\330\255\331\203\331\205 \331\201\331\212 \330\247\331\204\331\206\330\267\330\247\331\202\330\247\330\252 \330\247\331\204\330\254\330\272\330\261\330\247\331\201\331\212\330\251:\n```bash\nphp artisan migrate\n```\n\n---\n\n## \360\237\223\215 \331\203\331\212\331\201 \331\212\330\271\331\205\331\204 \331\201\330\255\330\265 \330\247\331\204\331\206\330\267\330\247\331\202 \330\247\331\204\330\254\330\272\330\261\330\247\331\201\331\212 \330\260\331\203\331\212\330\247\331\213 \331\201\331\212 Laravel\330\237\n\331\204\331\202\330\257 \331\202\331\205\331\206\330\247 \330\250\330\252\330\267\331\210\331\212\330\261 \331\205\331\212\330\262\330\251 \330\252\330\263\330\254\331\212\331\204 \330\247\331\204\330\255\330\266\331\210\330\261 \330\247\331\204\330\255\331\202\331\212\331\202\331\212\330\251 \331\201\331\212 `routes/api.php` \330\250\330\247\330\263\330\252\330\256\330\257\330\247\331\205 **\331\205\330\271\330\247\330\257\331\204\330\251 \331\207\330\247\331\201\331\212\330\261\330\263\331\212\331\206 \330\247\331\204\330\254\331\212\330\250\331\212\330\251 (Haversine Formula)** \331\204\330\255\330\263\330\247\330\250 \330\247\331\204\331\205\330\263\330\247\331\201\330\251 \330\247\331\204\330\257\331\202\331\212\331\202\330\251 \330\250\331\212\331\206 \330\247\331\204\331\205\331\210\330\270\331\201 \331\210\330\247\331\204\331\201\330\261\330\271 \330\250\330\247\331\204\330\243\331\205\330\252\330\247\330\261:\n\n```php\n// \331\212\330\252\331\205 \330\245\330\261\330\263\330\247\331\204 \330\245\330\255\330\257\330\247\330\253\331\212\330\247\330\252 \330\247\331\204\331\205\331\210\330\270\331\201 (Latitude, Longitude) \330\271\330\250\330\261 \330\247\331\204\330\252\330\267\330\250\331\212\331\202\n// \331\210\331\212\331\202\331\210\331\205 \330\247\331\204\330\256\330\247\330\257\331\205 \330\250\330\247\331\204\330\252\330\255\331\202\331\202 \331\205\331\206 \331\205\330\263\330\247\331\201\330\252\331\207 \330\250\330\247\331\204\331\206\330\263\330\250\330\251 \331\204\331\201\330\261\331\210\330\271 \330\264\330\261\331\203\330\252\331\207 \330\247\331\204\331\205\330\256\330\262\331\206\330\251\n$distance = $angle * $earthRadius; // \330\247\331\204\331\206\330\252\331\212\330\254\330\251 \330\250\330\247\331\204\330\243\331\205\330\252\330\247\330\261\n\nif ($distance <= $loc->radius) {\n    // \330\247\331\204\331\205\331\210\330\270\331\201 \331\205\330\252\331\210\330\247\330\254\330\257 \330\257\330\247\330\256\331\204 \330\247\331\204\330\257\330\247\330\246\330\261\330\251 \330\247\331\204\331\205\330\263\331\205\331\210\330\255\330\251!\n}\n```\n\n---\n\n## \360\237\232\200 \330\252\330\264\330\272\331\212\331\204 \330\256\330\247\330\257\331\205 \330\247\331\204\330\252\330\267\331\210\331\212\330\261 \331\210\330\247\331\204\331\210\330\247\330\254\331\207\330\247\330\252 \331\205\330\271\330\247\331\213\n\n\331\204\330\252\330\264\330\272\331\212\331\204 \330\256\330\247\330\257\331\205 Laravel \330\247\331\204\330\256\331\204\331\201\331\212 \331\210\330\256\330\247\330\257\331\205 Vite \331\204\330\250\331\206\330\247\330\241 \331\210\330\247\330\254\331\207\330\251 React \330\247\331\204\330\252\331\201\330\247\330\271\331\204\331\212\330\251\330\214 \330\247\331\201\330\252\330\255 \331\206\330\247\331\201\330\260\330\252\331\212\331\206 \331\201\331\212 \331\210\330\255\330\257\330\251 \330\247\331\204\330\252\330\255\331\203\331\205 (Terminal):\n\n**\330\247\331\204\331\206\330\247\331\201\330\260\330\251 \330\247\331\204\330\243\331\210\331\204\331\211 (\330\256\330\247\330\257\331\205 Laravel API):**\n```bash\nphp artisan serve\n```\n\n**\330\247\331\204\331\206\330\247\331\201\330\260\330\251 \330\247\331\204\330\253\330\247\331\206\331\212\330\251 (\330\256\330\247\330\257\331\205 Vite \331\204\330\250\331\206\330\247\330\241 React):**\n```bash\nnpm run dev\n```\n\n\330\247\331\204\330\242\331\206 \330\247\331\201\330\252\330\255 \330\247\331\204\331\205\330\252\330\265\331\201\330\255 \330\271\331\204\331\211 \330\247\331\204\330\261\330\247\330\250\330\267 \330\247\331\204\330\247\